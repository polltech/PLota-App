{
  "expo": {
    "name": "Plotra",
    "slug": "plotra-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0803"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "africa.plotra.polygon",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses GPS to capture farm boundaries for EUDR compliance.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Needed for continuous GPS tracking during boundary walk.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0803"
      },
      "package": "africa.plotra.polygon",
      "versionCode": 2,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_NETWORK_STATE",
        "INTERNET"
      ],
      "blockedPermissions": [
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "782dd611-cfda-4a7f-a283-64ade9d06430"
      }
    },
    "owner": "polldeveloper"
  }
}
